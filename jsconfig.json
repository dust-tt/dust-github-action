{
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "checkJs": true,
    "esModuleInterop": true,
    "lib": ["ESNext"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "target": "ESNext"
  },
  "exclude": ["node_modules", "dist"],
  "include": ["src/**/*.js"]
}
