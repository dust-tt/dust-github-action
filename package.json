{
  "name": "dust-github-action",
  "version": "1.0.0",
  "description": "Interact with your Dust workspace from GitHub Actions",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "ncc build src/index.js --license licenses.txt --source-map",
    "check": "tsc --noEmit --project ./jsconfig.json",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "node --test test/*.spec.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dust-tt/dust-github-action.git"
  },
  "keywords": [
    "dust",
    "github",
    "action",
    "skills",
    "agents"
  ],
  "author": "Dust",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "adm-zip": "^0.5.16",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/adm-zip": "^0.5.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.0",
    "@vercel/ncc": "^0.38.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
